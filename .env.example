# Entrypoint config. If empty, scripts default to EP v0.9 at 0x433709009B8330FDa32311DF1C2AFA402eD8D009.
ENTRYPOINT=

# AccountFactory's initial owner
ACCOUNT_FACTORY_OWNER=

# Expected addresses

ALLOWLIST_MODULE=
EXECUTION_INSTALL_DELEGATE=
NATIVE_TOKEN_LIMIT_MODULE=
PAYMASTER_GUARD_MODULE=
SINGLE_SIGNER_VALIDATION_MODULE=
TIME_RANGE_MODULE=
WEBAUTHN_VALIDATION_MODULE=

MODULAR_ACCOUNT_IMPL=
SEMI_MODULAR_ACCOUNT_7702_IMPL=
SEMI_MODULAR_ACCOUNT_BYTECODE_IMPL=
SEMI_MODULAR_ACCOUNT_STORAGE_ONLY_IMPL=

WEBAUTHN_ACCOUNT_FACTORY=
ACCOUNT_FACTORY=

# Deployment salts. If empty, defaults to 0x0.

ALLOWLIST_MODULE_SALT=
EXECUTION_INSTALL_DELEGATE_SALT=
NATIVE_TOKEN_LIMIT_MODULE_SALT=
PAYMASTER_GUARD_MODULE_SALT=
SINGLE_SIGNER_VALIDATION_MODULE_SALT=
TIME_RANGE_MODULE_SALT=
WEBAUTHN_VALIDATION_MODULE_SALT=

MODULAR_ACCOUNT_IMPL_SALT=
SEMI_MODULAR_ACCOUNT_7702_IMPL_SALT=
SEMI_MODULAR_ACCOUNT_BYTECODE_IMPL_SALT=
SEMI_MODULAR_ACCOUNT_STORAGE_ONLY_IMPL_SALT=

WEBAUTHN_ACCOUNT_FACTORY_SALT=
ACCOUNT_FACTORY_SALT=

# Factory staking setup

# Needs a new factory address variable, to address a foundry test suite issue with setEnv
ACCOUNT_FACTORY_TO_STAKE=

# Same as the ACCOUNT_FACTORY_TO_STAKE env variable, but specific to the WebAuthnFactory
WEBAUTHN_ACCOUNT_FACTORY_TO_STAKE=

# 0.1 ether required by bundlers
REQUIRED_STAKE_AMOUNT_WEI=100000000000000000
# 1 day required by bundlers
UNSTAKE_DELAY_SEC=86400
